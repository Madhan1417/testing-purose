## GitHub Actions CI/CD

### Required Secrets

Go to **GitHub repo → Settings → Secrets and variables → Actions** and add:

| Secret Name           | Value                        |
|-----------------------|------------------------------|
| EC2_IP                | Your EC2 public IP           |
| EC2_USER              | ubuntu                       |
| EC2_SSH_KEY           | Full content of your .pem file |
| AWS_ACCESS_KEY_ID     | Your AWS access key          |
| AWS_SECRET_ACCESS_KEY | Your AWS secret key          |
| AWS_REGION            | Your AWS region (e.g. us-east-1) |
| SG_ID                 | Your security group ID       |

---

### Main Workflow — deploy.yml

Triggers on every push to master branch.

name: Deploy to EC2

on:
  push:
    branches:
      - master
      - qa

jobs:
  deploy:
    runs-on: ubuntu-latest

    steps:
      - name: Set Environment Variables
        run: |
          if [ "${{ github.ref_name }}" == "master" ]; then
            echo "EC2_HOST=${{ secrets.EC2_IP }}" >> $GITHUB_ENV
            echo "DEPLOY_PATH=/home/ubuntu/testing-purose" >> $GITHUB_ENV
            echo "PM2_APP=app" >> $GITHUB_ENV
            echo "BRANCH=master" >> $GITHUB_ENV

          elif [ "${{ github.ref_name }}" == "qa" ]; then
            echo "EC2_HOST=${{ secrets.QA_EC2_IP }}" >> $GITHUB_ENV
            echo "DEPLOY_PATH=/home/ubuntu/testing-purose-qa" >> $GITHUB_ENV
            echo "PM2_APP=qa-app" >> $GITHUB_ENV
            echo "BRANCH=qa" >> $GITHUB_ENV

          else
            echo "Branch not allowed for deployment"
            exit 1
          fi

      - name: Get GitHub IP and Open Firewall
        run: |
          GITHUB_IP=$(curl -s https://api.ipify.org)
          echo "GITHUB_IP=$GITHUB_IP" >> $GITHUB_ENV
          echo "Opening firewall for $GITHUB_IP"
          aws ec2 authorize-security-group-ingress \
            --group-id "${{ secrets.SG_ID }}" \
            --protocol tcp \
            --port 22 \
            --cidr ${GITHUB_IP}/32 || true
        env:
          AWS_ACCESS_KEY_ID: ${{ secrets.AWS_ACCESS_KEY_ID }}
          AWS_SECRET_ACCESS_KEY: ${{ secrets.AWS_SECRET_ACCESS_KEY }}
          AWS_DEFAULT_REGION: ${{ secrets.AWS_REGION }}

      - name: Deploy to EC2
        uses: appleboy/ssh-action@master
        with:
          host: ${{ env.EC2_HOST }}
          username: ${{ secrets.EC2_USER }}
          key: ${{ secrets.EC2_SSH_KEY }}
          script: |
            export NVM_DIR="$HOME/.nvm"
            [ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
            export PATH=$PATH:/usr/local/bin

            cd ${{ env.DEPLOY_PATH }}
            git fetch origin
            git reset --hard origin/${{ env.BRANCH }}

            sudo chown -R ubuntu:ubuntu ${{ env.DEPLOY_PATH }}

            pm2 stop ${{ env.PM2_APP }} || true
            pm2 start ${{ env.DEPLOY_PATH }}/backend/app.js --name ${{ env.PM2_APP }}
            pm2 save

            sudo systemctl restart nginx

            echo "Deployed to ${{ env.BRANCH }} successfully!"

      - name: Remove IP from Firewall
        if: always()
        run: |
          echo "Closing firewall for $GITHUB_IP"
          aws ec2 revoke-security-group-ingress \
            --group-id "${{ secrets.SG_ID }}" \
            --protocol tcp \
            --port 22 \
            --cidr ${GITHUB_IP}/32 || true
        env:
          AWS_ACCESS_KEY_ID: ${{ secrets.AWS_ACCESS_KEY_ID }}
          AWS_SECRET_ACCESS_KEY: ${{ secrets.AWS_SECRET_ACCESS_KEY }}
          AWS_DEFAULT_REGION: ${{ secrets.AWS_REGION }}
