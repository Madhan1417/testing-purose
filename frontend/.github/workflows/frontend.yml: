name: Deploy Frontend

on:
  push:
    branches:
      - master
    paths:
      - 'frontend/**'

jobs:
  deploy-frontend:
    runs-on: ubuntu-latest

    steps:
      - name: Deploy Frontend to EC2
        uses: appleboy/ssh-action@master
        with:
          host: ${{ secrets.EC2_IP }}
          username: ${{ secrets.EC2_USER }}
          key: ${{ secrets.EC2_SSH_KEY }}
          script: |
            cd /home/ubuntu/testing-purose
            git fetch origin
            git reset --hard origin/master
            sudo chown -R ubuntu:ubuntu /home/ubuntu/testing-purose/frontend
            sudo chmod 755 /home/ubuntu/testing-purose/frontend
            sudo chmod 644 /home/ubuntu/testing-purose/frontend/index.html
            sudo systemctl restart nginx
            echo "Frontend deployed successfully!"
